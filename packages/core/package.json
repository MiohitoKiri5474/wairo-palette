{
  "name": "@wairo-palette/core",
  "version": "0.1.0",
  "description": "Traditional Japanese colors — typed constants",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist", "src/data/colors.json"],
  "scripts": {
    "build": "unbuild",
    "test": "vitest run"
  },
  "publishConfig": {
    "access": "public"
  }
}
