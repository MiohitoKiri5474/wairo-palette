{
  "name": "@wairo-palette/tailwind",
  "version": "0.1.1",
  "description": "Traditional Japanese colors — Tailwind CSS plugin",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "test": "vitest run"
  },
  "dependencies": {
    "@wairo-palette/core": "workspace:*"
  },
  "peerDependencies": {
    "tailwindcss": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
