{
  "name": "nippon-color",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "dev:docs": "pnpm --filter docs dev",
    "build:docs": "pnpm --filter docs build",
    "publish:npm": "pnpm -r --filter './packages/*' publish --access public",
    "publish:jsr": "pnpm -r --filter './packages/*' exec jsr publish"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.16.0",
    "vitest": "^2.0.0",
    "unbuild": "^3.0.0"
  }
}
